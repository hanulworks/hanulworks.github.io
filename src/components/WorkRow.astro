---
import type { WorkRowProps } from "../types/work-row";

const {
  title,
  description = "",
  year,
  links = [],
  tags = [],
  image,
  imageAlt = "",
  imageFetchPriority,
  imageThumbnailScale,
} = Astro.props as WorkRowProps;
const listingLinks = (links || []).filter((l) => l.surface !== "detailOnly");
const thumbZoom =
  typeof imageThumbnailScale === "number" &&
  imageThumbnailScale > 1 &&
  Number.isFinite(imageThumbnailScale);
---

<article class="work-row card">
  <div class="work-meta">
    <h3 class="work-row__title colorful">{title}</h3>
    {description && <p class="work-row__description">{description}</p>}
    {year && <span class="work-row__year">{year}</span>}
    {
      listingLinks.length > 0 && (
        <ul class="work-row__links">
          {listingLinks.map((link) => (
            <li>
              {(() => {
                const isExternal =
                  (typeof link.external === "boolean" && link.external) ||
                  (typeof link.href === "string" &&
                    (link.href.startsWith("http://") ||
                      link.href.startsWith("https://")));
                const isInternal =
                  !isExternal ||
                  (typeof link.label === "string" &&
                    link.label.toUpperCase() === "VIEW DETAILS");
                const linkClass = `work-link ${isInternal ? "work-link--internal" : "work-link--external"}`;
                return (
                  <a
                    href={link.href}
                    class={linkClass}
                    target={isInternal ? undefined : "_blank"}
                    rel={isInternal ? undefined : "noopener noreferrer"}
                    aria-label={
                      isInternal ? link.label : `${link.label} (opens in new tab)`
                    }
                  >
                    {link.label}
                  </a>
                );
              })()}
            </li>
          ))}
        </ul>
      )
    }
  </div>
  {
    image && (
      <figure
        class:list={["work-row__image", thumbZoom && "work-row__image--thumb-zoom"]}
        style={thumbZoom
          ? { "--work-row-thumb-scale": String(imageThumbnailScale) }
          : undefined}
      >
        <img
          src={image}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          {...(imageFetchPriority ? { fetchpriority: imageFetchPriority } : {})}
        />
      </figure>
    )
  }
  {
    tags.length > 0 && (
      <div class="work-row__tags">
        {tags.map((tag) => (
          <span class="chip">{tag}</span>
        ))}
      </div>
    )
  }
</article>

<style>
  /* Slight center zoom (letterbox / focus); clipping + radius come from global .work-row__image */
  .work-row__image--thumb-zoom img {
    transform: scale(var(--work-row-thumb-scale, 1.15));
    transform-origin: center center;
  }
</style>
