---
import BaseLayout from "./BaseLayout.astro";
import type { WorkLink } from "../types/work-row";

export interface DetailLayoutProps {
  title: string;
  description?: string;
  /** false: meta description only, no visible blurb */
  showDescriptionInHeader?: boolean;
  year?: string;
  links?: WorkLink[];
  tags?: string[];
  tools?: string;
  language?: string;
}

const {
  title,
  description = "",
  showDescriptionInHeader = true,
  year,
  links = [],
  tags = [],
  tools = "",
  language = "",
} = Astro.props as DetailLayoutProps;

const detailOnlyLinks = (links || []).filter((l) => l.surface === "detailOnly");
---

<BaseLayout {title} description={description}>
  <main id="content" class="detail-page">
    <div class="card card--square">
      <header aria-labelledby="detail-title" class="work-row detail-header">
        <div class="work-meta">
          <h3 id="detail-title" class="work-row__title">{title}</h3>
          {
            showDescriptionInHeader && description && (
              <p class="work-row__description">{description}</p>
            )
          }
          {year && <p class="work-row__year">{year}</p>}
          {
            detailOnlyLinks.length > 0 && (
              <ul class="work-row__links">
                {detailOnlyLinks.map((link) => (
                  <li>
                    <a
                      class={`work-link ${link.external ? "work-link--external" : "work-link--internal"}`}
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>

        <div class="detail-right">
          {
            tags.length > 0 && (
              <div class="work-row__tags">
                {tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )
          }

          {
            (tools || language) && (
              <div class="work-links-and-meta">
                {tools && <p class="text">Tools | {tools}</p>}
                {language && <p class="text">Language | {language}</p>}
              </div>
            )
          }
        </div>
      </header>
      <slot />
    </div>
  </main>
</BaseLayout>
