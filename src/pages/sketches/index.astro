---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkRow from "../../components/WorkRow.astro";
import sketchCatalog from "../../data/sketches";
---

<BaseLayout
  title="Sketches"
  description="Interactive sketches and generative work by Hanul Park"
  bodyClass="page-sketches"
>
  <main id="content">
    <section class="work-section" aria-label="Sketches">
      {
        sketchCatalog.map((sketch) => (
          <WorkRow
            title={sketch.title}
            description={sketch.description ?? ""}
            year={sketch.year}
            links={sketch.links ?? []}
            tags={sketch.tags ?? []}
            image={sketch.image}
            imageAlt={sketch.imageAlt ?? ""}
            imageFetchPriority="low"
            imageThumbnailScale={sketch.imageThumbnailScale}
          />
        ))
      }
    </section>
  </main>
</BaseLayout>
