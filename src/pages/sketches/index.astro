---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkRow from "../../components/WorkRow.astro";
import sketchItems from "../../data/sketches";
---

<BaseLayout
  title="Sketches"
  description="Interactive sketches and generative work by Hanul Park"
  bodyClass="page-sketches"
>
  <main id="content">
    <section class="work-section" aria-label="Sketches">
      {
        sketchItems.map((sketch) => (
          <WorkRow
            title={sketch.title}
            synopsis={sketch.synopsis ?? ""}
            year={sketch.year}
            links={sketch.links ?? []}
            domains={sketch.domains ?? []}
            image={sketch.image}
            imageAlt={sketch.imageAlt ?? ""}
            imageFetchPriority="low"
          />
        ))
      }
    </section>
  </main>
</BaseLayout>
