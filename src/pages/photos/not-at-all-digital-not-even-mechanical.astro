---
import DetailLayout from "../../layouts/DetailLayout.astro";
import PhotoSeriesGallery from "../../components/PhotoSeriesGallery.astro";
import { getPhotoSeriesBySlug } from "../../data/photos";
import { sortGlobUrlsByNumericStem } from "../../utils/sortGlobUrlsByNumericStem";

const series = getPhotoSeriesBySlug("not-at-all-digital-not-even-mechanical");
if (!series) {
  throw new Error(
    "Photo series not found for 'not-at-all-digital-not-even-mechanical'",
  );
}

const {
  title,
  synopsis,
  year,
  domains = [],
  links = [],
  tools,
  language,
} = series;

const imageEntries = Object.entries(
  import.meta.glob("/public/photos/not-at-all-digital/*.JPEG", {
    eager: true,
    as: "url",
  }),
) as [string, string][];

const imageUrls = sortGlobUrlsByNumericStem(imageEntries);
const leadImage = imageUrls[0];
const galleryImages = imageUrls.slice(1);
---

<DetailLayout
  {title}
  {synopsis}
  {year}
  {domains}
  {links}
  {tools}
  {language}
  showSynopsisInHeader={false}
>
  <PhotoSeriesGallery
    slug="not-at-all-digital-not-even-mechanical"
    seriesTitle="Not At All Digital, Not Even Mechanical"
    leadImage={leadImage}
    galleryImages={galleryImages}
  />
</DetailLayout>
