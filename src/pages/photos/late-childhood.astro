---
import DetailLayout from "../../layouts/DetailLayout.astro";
import PhotoSeriesGallery from "../../components/PhotoSeriesGallery.astro";
import { getPhotoBySlug } from "../../data/photos";
import { sortGlobUrlsByNumericStem } from "../../utils/sortPhotoPaths";

const project = getPhotoBySlug("late-childhood");
if (!project) {
  throw new Error("Photo series not found for 'late-childhood'");
}

const {
  title,
  synopsis,
  year,
  domains = [],
  links = [],
  tools,
  language,
} = project;

const imageEntries = Object.entries(
  import.meta.glob("/public/photos/late-childhood/*.JPEG", {
    eager: true,
    as: "url",
  }),
) as [string, string][];

const imageUrls = sortGlobUrlsByNumericStem(imageEntries);
const leadImage = imageUrls[0];
const galleryImages = imageUrls.slice(1);
---

<DetailLayout
  {title}
  {synopsis}
  {year}
  {domains}
  {links}
  {tools}
  {language}
  showSynopsisInHeader={false}
>
  <PhotoSeriesGallery
    slug="late-childhood"
    seriesTitle="Late Childhood"
    leadImage={leadImage}
    galleryImages={galleryImages}
  />
</DetailLayout>
