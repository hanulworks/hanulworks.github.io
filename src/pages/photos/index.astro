---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkRow from "../../components/WorkRow.astro";
import photoSeries, { toWorkRowPropsFromPhotoSeries } from "../../data/photos";
---

<BaseLayout title="Photos" description="Photography series by Hanul Park">
  <main id="content">
    <section class="work-section" aria-label="Photography series list">
      {
        photoSeries.map((series) => (
          <WorkRow {...toWorkRowPropsFromPhotoSeries(series)} />
        ))
      }
    </section>
  </main>
</BaseLayout>
