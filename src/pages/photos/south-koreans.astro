---
import DetailLayout from "../../layouts/DetailLayout.astro";
import PhotoSeriesGallery from "../../components/PhotoSeriesGallery.astro";
import { getPhotoSeriesBySlug } from "../../data/photos";
import { sortGlobUrlsByNumericStem } from "../../utils/sortGlobUrlsByNumericStem";

const series = getPhotoSeriesBySlug("south-koreans");
if (!series) {
  throw new Error("Photo series not found for 'south-koreans'");
}

const {
  title,
  synopsis,
  year,
  domains = [],
  links = [],
  tools,
  language,
} = series;

const imageEntries = Object.entries(
  import.meta.glob("/public/photos/south-koreans/*.JPEG", {
    eager: true,
    as: "url",
  }),
) as [string, string][];

const imageUrls = sortGlobUrlsByNumericStem(imageEntries);
const leadImage = imageUrls[0];
const galleryImages = imageUrls.slice(1);
---

<DetailLayout
  {title}
  {synopsis}
  {year}
  {domains}
  {links}
  {tools}
  {language}
  showSynopsisInHeader={false}
>
  <PhotoSeriesGallery
    slug="south-koreans"
    seriesTitle="South Koreans"
    leadImage={leadImage}
    galleryImages={galleryImages}
  />
</DetailLayout>
