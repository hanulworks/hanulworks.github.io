---
import DetailLayout from "../../layouts/DetailLayout.astro";
import { getProjectBySlug } from "../../data/projects";

const project = getProjectBySlug("media-smart-citizens");
if (!project) {
  throw new Error("Project data not found for 'media-smart-citizens'");
}

const {
  title,
  synopsis,
  year,
  domains = [],
  links = [],
  tools,
  language,
} = project;

const mediaEntries = Object.entries(
  import.meta.glob(
    "/public/commercial/media-smart-citizens/*.{png,jpg,jpeg,JPG,JPEG,webp,gif}",
    { eager: true, as: "url" },
  ),
) as [string, string][];

type MediaItem = {
  url: string;
  fileName: string;
  stem: string;
  normalized: string;
  isWhiteMark: boolean;
};

const mediaItems: MediaItem[] = mediaEntries
  .map(([path, url]) => {
    const fileName = path.split("/").pop() ?? "";
    const stem = fileName.replace(/\.[^.]+$/, "");
    return {
      url,
      fileName,
      stem,
      normalized: fileName.toLowerCase(),
      isWhiteMark: /^(initials-white|logo-white)\./i.test(fileName),
    };
  })
  .sort((a, b) => a.fileName.localeCompare(b.fileName, undefined, { numeric: true }));

const byFile = (name: string) => mediaItems.find((m) => m.fileName === name);

const primaryLogo = byFile("logo.png");

const initialsMark = byFile("initials.png");
const nameMark = byFile("name.png");

const guidelineTypography = mediaItems.filter((m) =>
  /^town-10-display-/i.test(m.fileName),
);
const guidelineGradient = byFile("gradient.png");

const lockupVariationOrder = [
  "logo-black.png",
  "logo-white.png",
  "initials-black.png",
  "initials-white.png",
  "name-black.png",
  "name-purple.png",
] as const;
const guidelineLockups = lockupVariationOrder
  .map((fn) => byFile(fn))
  .filter((m): m is MediaItem => Boolean(m));

const slideDeckItems = mediaItems.filter((m) => /^slide-deck_/i.test(m.fileName));
const webLayoutItems = mediaItems.filter((m) => /^landing-page_/i.test(m.fileName));

const usedUrls = new Set<string>([
  ...(primaryLogo ? [primaryLogo.url] : []),
  ...(initialsMark ? [initialsMark.url] : []),
  ...(nameMark ? [nameMark.url] : []),
  ...guidelineTypography.map((m) => m.url),
  ...(guidelineGradient ? [guidelineGradient.url] : []),
  ...guidelineLockups.map((m) => m.url),
  ...slideDeckItems.map((m) => m.url),
  ...webLayoutItems.map((m) => m.url),
]);

const uncategorizedItems = mediaItems.filter((m) => !usedUrls.has(m.url));
---

<DetailLayout {title} {synopsis} {year} {domains} {links} {tools} {language}>
  <section class="text">
    <h6 class="section">I. BRAND IDENTITY SYSTEM</h6>
    <p class="subject">SCOPE</p>
    <p class="text">
      Established the primary brand mark and the core abbreviated and wordmark
      forms so the initiative reads clearly at full scale and in supporting
      applications.
    </p>

    <p class="subject">PRIMARY LOGO</p>
    {primaryLogo ? (
      <figure class="detailImage msc-primary-logo">
        <img
          class="msc-image msc-image--primary"
          src={primaryLogo.url}
          alt={`${title} complete logo`}
          loading="eager"
        />
      </figure>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add logo.png as the complete logo.</div>
      </figure>
    )}

    <p class="subject">LOCKUPS</p>
    <p class="text">
      Approved secondary marks sit below the primary logo: a monogram for
      compact contexts and a dedicated wordmark for horizontal lockups.
    </p>

    <div class="msc-mark-pair">
      {initialsMark ? (
        <div class="msc-mark-block">
          <figure class="detailImage msc-cell msc-cell--mark">
            <img
              class="msc-image msc-image--mark"
              src={initialsMark.url}
              alt={`${title} monogram mark`}
              loading="lazy"
            />
          </figure>
          <p class="text msc-mark-copy">
            Monogram mark for tight spaces, social avatars, and moments where a
            short glyph reads faster than the full name.
          </p>
        </div>
      ) : null}
      {nameMark ? (
        <div class="msc-mark-block">
          <figure class="detailImage msc-cell msc-cell--mark">
            <img
              class="msc-image msc-image--mark"
              src={nameMark.url}
              alt={`${title} wordmark`}
              loading="lazy"
            />
          </figure>
          <p class="text msc-mark-copy">
            Wordmark for headlines, horizontal layouts, and anywhere the full
            initiative name should carry the voice of the brand.
          </p>
        </div>
      ) : null}
    </div>
  </section>

  <section class="text">
    <h6 class="section">II. BRAND GUIDELINES</h6>
    <p class="subject">SCOPE</p>
    <p class="text">
      Documented typography, color and gradient behavior, and approved lockup
      variations so teams can implement the system without drifting off brand.
    </p>

    <p class="subject">TYPOGRAPHY</p>
    {guidelineTypography.length > 0 ? (
      <div class="msc-grid msc-grid--guidelines" role="list">
        {guidelineTypography.map((item) => (
          <figure class="detailImage msc-cell" role="listitem">
            <img
              class="msc-image"
              src={item.url}
              alt={`${title} typography sample`}
              loading="lazy"
            />
            <figcaption class="msc-caption">Primary typeface in use</figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add typography guideline assets.</div>
      </figure>
    )}
    <p class="text msc-after-grid">
      Town type treatment sets the editorial voice for titles and display lines
      across deck and web surfaces.
    </p>

    <p class="subject">GRADIENT AND COLOR PALETTE</p>
    {guidelineGradient ? (
      <figure class="detailImage msc-cell msc-gradient-figure">
        <img
          class="msc-image msc-image--gradient"
          src={guidelineGradient.url}
          alt={`${title} brand gradient and palette`}
          loading="lazy"
        />
      </figure>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add gradient.png for palette guidance.</div>
      </figure>
    )}
    <p class="text msc-after-grid">
      The gradient anchors the palette and signals motion and depth; paired
      neutrals and accent hues support UI, print, and presentation layers.
    </p>

    <p class="subject">LOCKUP VARIATIONS</p>
    {guidelineLockups.length > 0 ? (
      <div class="msc-grid msc-grid--logos" role="list">
        {guidelineLockups.map((item) => (
          <figure class="detailImage msc-cell" role="listitem">
            <img
              class={item.isWhiteMark ? "msc-image msc-image--dark-bg" : "msc-image"}
              src={item.url}
              alt={`${title} lockup variation`}
              loading="lazy"
            />
            <figcaption class="msc-caption">Approved variation</figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add lockup variation assets.</div>
      </figure>
    )}
    <p class="text msc-after-grid">
      Light and dark treatments keep the mark legible on neutral, tinted, and
      photographic backgrounds.
    </p>
  </section>

  <section class="text">
    <h6 class="section">III. SLIDE DECK SYSTEM</h6>
    <p class="subject">SCOPE</p>
    <p class="text">
      Created a deck framework for structured storytelling, balancing narrative
      clarity with reusable layouts for stakeholder communication.
    </p>
    <p class="subject">KEY OUTPUTS</p>
    {slideDeckItems.length > 0 ? (
      <div class="msc-grid" role="list" aria-label="Media Smart Citizens slide deck assets">
        {slideDeckItems.map((item) => (
          <figure class="detailImage msc-cell" role="listitem">
            <img
              class={item.isWhiteMark ? "msc-image msc-image--dark-bg" : "msc-image"}
              src={item.url}
              alt={`${title} slide ${item.stem}`}
              loading="lazy"
            />
            <figcaption class="msc-caption">{item.stem}</figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add slide deck assets to this section.</div>
      </figure>
    )}
  </section>

  <section class="text">
    <h6 class="section">IV. WEBSITE UX REFINEMENT</h6>
    <p class="subject">SCOPE</p>
    <p class="text">
      Extended the identity into website layout studies with clearer visual
      hierarchy, improved scanning patterns, and better page-level composition.
    </p>
    <p class="subject">KEY OUTPUTS</p>
    {webLayoutItems.length > 0 ? (
      <div class="msc-grid" role="list" aria-label="Media Smart Citizens website layout assets">
        {webLayoutItems.map((item) => (
          <figure class="detailImage msc-cell" role="listitem">
            <img
              class={item.isWhiteMark ? "msc-image msc-image--dark-bg" : "msc-image"}
              src={item.url}
              alt={`${title} layout ${item.stem}`}
              loading="lazy"
            />
            <figcaption class="msc-caption">{item.stem}</figcaption>
          </figure>
        ))}
      </div>
    ) : (
      <figure class="detailImage detailImage--placeholder">
        <div class="asset-placeholder">Add website UX assets to this section.</div>
      </figure>
    )}
  </section>

  {uncategorizedItems.length > 0 && (
    <section class="text">
      <h6 class="section">V. ADDITIONAL ASSETS</h6>
      <p class="subject">SUPPORTING MATERIALS</p>
      <p class="text">
        Files not assigned to the sections above are listed here so nothing is
        omitted from the case study.
      </p>
      <div class="msc-grid" role="list" aria-label="Additional Media Smart Citizens assets">
        {uncategorizedItems.map((item) => (
          <figure class="detailImage msc-cell" role="listitem">
            <img
              class={item.isWhiteMark ? "msc-image msc-image--dark-bg" : "msc-image"}
              src={item.url}
              alt={`${title} ${item.stem}`}
              loading="lazy"
            />
            <figcaption class="msc-caption">{item.stem}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  )}
</DetailLayout>

<style>
  .msc-primary-logo {
    margin: 0 0 var(--space-md);
    max-width: min(100%, 420px);
  }

  .msc-image--primary {
    height: clamp(140px, 24vw, 220px);
    background: color-mix(in srgb, white 92%, transparent);
  }

  /* Match site detail grid: wrappers must sit in the wide (0.8fr) column — see public/style.css section.text @992px */
  @media (min-width: 992px) {
    section.text > .msc-mark-pair,
    section.text > .msc-grid {
      grid-column: 2;
    }
  }

  .msc-mark-pair {
    display: grid;
    gap: clamp(1rem, 3vw, 1.75rem);
    grid-template-columns: 1fr;
    width: 100%;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .msc-mark-pair {
      /* Slightly favor the horizontal wordmark column */
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
    }
  }

  .msc-mark-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    min-width: 0;
  }

  .msc-cell--mark {
    max-width: none;
    width: 100%;
  }

  .msc-mark-copy {
    margin: 0;
    max-width: none;
  }

  .msc-after-grid {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .msc-gradient-figure {
    max-width: min(100%, 360px);
    margin-bottom: 0;
  }

  .msc-image--gradient {
    height: clamp(100px, 18vw, 180px);
  }

  .msc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: clamp(8px, 1.2vw, 14px);
  }

  .msc-grid--logos {
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  }

  .msc-grid--guidelines {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  }

  .msc-cell {
    margin: 0;
    padding: 8px;
    border: 1px solid color-mix(in srgb, var(--color-text) 18%, transparent);
    background: color-mix(in srgb, var(--color-accent-muted) 5%, transparent);
    border-radius: 6px;
  }

  .msc-image {
    width: 100%;
    height: clamp(88px, 12vw, 160px);
    object-fit: contain;
    object-position: center;
    background: color-mix(in srgb, white 88%, transparent);
  }

  /* After .msc-image so lockup marks keep flexible height for horizontal wordmark */
  .msc-image.msc-image--mark {
    height: auto;
    min-height: 120px;
    max-height: 200px;
  }

  .msc-image--dark-bg {
    background: linear-gradient(135deg, #111827, #334155);
  }

  .msc-caption {
    margin-top: 0.35rem;
    font-size: 0.7rem;
    color: var(--color-text);
    opacity: 0.72;
    text-align: left;
    line-height: 1.25;
    word-break: break-word;
  }

  .detailImage--placeholder {
    border: 1px dashed var(--color-text);
    background: color-mix(in srgb, var(--color-accent-muted) 8%, transparent);
    min-height: clamp(220px, 40vw, 420px);
    display: grid;
    place-items: center;
    margin: 0;
  }

  .asset-placeholder {
    padding: 1rem 1.25rem;
    text-align: center;
    color: var(--color-text);
    font-size: var(--text-sm);
    opacity: 0.8;
  }

  @media (min-width: 1200px) {
    .msc-grid {
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    }
  }
</style>
