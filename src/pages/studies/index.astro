---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkRow from "../../components/WorkRow.astro";
import { getStudiesListing, toWorkRowProps } from "../../data/site-data";
---

<BaseLayout title="Studies" description="Studies and research projects by Hanul Park">
  <main id="content">
    <section class="work-section" aria-label="Studies">
      {getStudiesListing().map((entry) => <WorkRow {...toWorkRowProps(entry)} />)}
    </section>
  </main>
</BaseLayout>
